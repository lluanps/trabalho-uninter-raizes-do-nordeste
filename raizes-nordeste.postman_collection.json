            "url": { "raw": "{{baseUrl}}/unidades/1", "host": ["{{baseUrl}}"], "path": ["unidades","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Unidade Recife Centro - Atualizada\",\n  \"endereco\": \"Rua da Aurora, 200, Recife - PE\",\n  \"telefone\": \"(81) 99999-0002\"\n}" }
          }
