{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção completa de endpoints da API REST da rede de lanchonetes Raízes do Nordeste.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.token) { pm.collectionVariables.set('token', json.token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@raizesdonordeste.com.br\",\n  \"senha\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Login - credenciais inválidas (negativo)",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@raizesdonordeste.com.br\",\n  \"senha\": \"senhaerrada\"\n}" }
          }
        },
        {
          "name": "Registro de usuário",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/registro", "host": ["{{baseUrl}}"], "path": ["auth","registro"] },
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Novo Cliente\",\n  \"email\": \"novo@email.com\",\n  \"senha\": \"Senha@123\",\n  \"cpf\": \"111.222.333-44\",\n  \"consentimentoLgpd\": true\n}" }
          }
        },
        {
          "name": "Registro - email inválido (negativo)",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/registro", "host": ["{{baseUrl}}"], "path": ["auth","registro"] },
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Teste\",\n  \"email\": \"emailinvalido\",\n  \"senha\": \"123\",\n  \"cpf\": \"111.222.333-44\",\n  \"consentimentoLgpd\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Listar usuários",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/usuarios?page=0&size=10", "host": ["{{baseUrl}}"], "path": ["usuarios"], "query": [{"key":"page","value":"0"},{"key":"size","value":"10"}] }
          }
        },
        {
          "name": "Buscar usuário por ID",
          "request": {
            "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/usuarios/1", "host": ["{{baseUrl}}"], "path": ["usuarios","1"] }
          }
        },
        {
          "name": "Atualizar usuário",
          "request": {
            "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" },{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/usuarios/1", "host": ["{{baseUrl}}"], "path": ["usuarios","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Administrador Atualizado\",\n  \"email\": \"admin@raizesdonordeste.com.br\",\n  \"senha\": \"Admin@123\",\n  \"cpf\": \"000.000.000-01\",\n  \"consentimentoLgpd\": true\n}" }
          }
        },
        {
          "name": "Deletar usuário",
          "request": {
            "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/usuarios/99", "host": ["{{baseUrl}}"], "path": ["usuarios","99"] }
          }
        },
        {
          "name": "Listar usuários - sem token (negativo)",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/usuarios", "host": ["{{baseUrl}}"], "path": ["usuarios"] }
          }
        }
      ]
    },
