            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Tapioca de Queijo\",\n  \"descricao\": \"Tapioca artesanal com queijo coalho\",\n  \"preco\": 12.50,\n  \"categoria\": \"Salgado\"\n}" }
